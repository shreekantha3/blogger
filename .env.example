# Blogger Automation Platform - Environment Configuration
# Copy this to .env and fill in your values

# Google OAuth Configuration
GOOGLE_CLIENT_SECRET_PATH=client_secret.json
GOOGLE_CREDENTIALS_STORAGE_PATH=credentials.storage

# Blogger Configuration
BLOGGER_BLOG_ID=

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=plain
LOG_FILE_PATH=logs/blogger_automation.log

# AI Configuration (Phase 4 - set your preferred provider)
OPENROUTER_API_KEY=your_openrouter_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# AI Model Configuration (OpenRouter uses model/v1 format)
AI_DEFAULT_PROVIDER=openrouter
AI_DEFAULT_MODEL=meta-llama/llama-3.3-70b-instruct:free
AI_MAX_TOKENS=10000
AI_TEMPERATURE=0.7

# Media Configuration (Phase 5)
IMAGE_STORAGE_PATH=data/images/

# Application Configuration
APP_DEBUG=false
APP_ENV=development