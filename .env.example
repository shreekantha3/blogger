# Blogger Automation Platform - Environment Configuration
# Copy this to .env and fill in your values

# Your Blogger Blog ID (find in Blogger dashboard URL: blog ID is the number)
blogger_blog_id=YOUR_BLOG_ID_HERE

# Optional: API keys for AI features (Phase 4)
openrouter_api_key=sk-or-...
anthropic_api_key=sk-ant-...
openai_api_key=sk-...

# Logging
log_level=INFO
log_format=json
